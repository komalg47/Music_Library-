package com.music_library.user_service.exception;

/**
 * Custom exception class for handling invalid request scenarios.
 * This exception is thrown when the request contains invalid or missing data.
 * 
 * @author MusicVerse Team
 * @version 1.0
 * @since 2024
 */
public class InvalidRequestException extends RuntimeException {

    /**
     * Constructs a new InvalidRequestException with the specified detail message.
     * 
     * @param message the detail message explaining the invalid request error
     */
    public InvalidRequestException(String message) {
        super(message);
    }

    /**
     * Constructs a new InvalidRequestException with the specified detail message and cause.
     * 
     * @param message the detail message explaining the invalid request error
     * @param cause the cause of this exception
     */
    public InvalidRequestException(String message, Throwable cause) {
        super(message, cause);
    }
}
