package com.music_library.user_service.exception;

/**
 * Custom exception class for handling authentication failures.
 * This exception is thrown when user authentication fails due to invalid credentials.
 * 
 * @author MusicVerse Team
 * @version 1.0
 * @since 2024
 */
public class AuthenticationException extends RuntimeException {

    /**
     * Constructs a new AuthenticationException with the specified detail message.
     * 
     * @param message the detail message explaining the authentication failure
     */
    public AuthenticationException(String message) {
        super(message);
    }

    /**
     * Constructs a new AuthenticationException with the specified detail message and cause.
     * 
     * @param message the detail message explaining the authentication failure
     * @param cause the cause of this exception
     */
    public AuthenticationException(String message, Throwable cause) {
        super(message, cause);
    }
}
