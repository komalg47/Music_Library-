package com.music_library.admin_service.exception;

/**
 * Custom exception class for handling duplicate resource scenarios.
 * This exception is thrown when attempting to create a resource that already exists.
 * 
 * @author MusicVerse Team
 * @version 1.0
 * @since 2024
 */
public class DuplicateResourceException extends RuntimeException {

    /**
     * Constructs a new DuplicateResourceException with the specified detail message.
     * 
     * @param message the detail message explaining the duplicate resource error
     */
    public DuplicateResourceException(String message) {
        super(message);
    }

    /**
     * Constructs a new DuplicateResourceException with the specified detail message and cause.
     * 
     * @param message the detail message explaining the duplicate resource error
     * @param cause the cause of this exception
     */
    public DuplicateResourceException(String message, Throwable cause) {
        super(message, cause);
    }
}
